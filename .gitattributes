* text=auto

*.py text eol=crlf
*.pyproj text eol=crlf
*.sln text eol=crlf
*.txt text eol=crlf
*.md text eol=crlf

*.png binary
*.ico binary
*.wav binary

# Build/codegen output - never hand-edited, always regenerated byte-for-byte
# by its own tool (Vite / the schema codegen script / the Python Tailwind
# theme generator). `* text=auto` above plus a local core.autocrlf=true
# otherwise makes every fresh build spuriously "modify" these paths in
# `git status`, since the tool writes LF directly while git expects the
# working-tree copy to match its own checkout-time normalization. -text
# opts them out of line-ending normalization entirely, so they stay exactly
# as their generator wrote them.
assets/composer/** -text
web_ui/src/lib/bridge-core/generated/** -text
web_ui/src/lib/tokens/gl-theme.css -text
