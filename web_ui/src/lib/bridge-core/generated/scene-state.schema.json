{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "dragFactor": {
      "type": "number"
    },
    "edges": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "source",
          "target"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "fontColor": {
      "type": "string"
    },
    "fontFamily": {
      "type": "string"
    },
    "fontSizePt": {
      "type": "integer"
    },
    "minCompatibleSchemaVersion": {
      "type": "integer"
    },
    "nodes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "attachmentKind": {
            "type": "string"
          },
          "byteSize": {
            "type": "integer"
          },
          "code": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "durationSeconds": {
            "type": "number"
          },
          "filePath": {
            "type": "string"
          },
          "history": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "content": {
                  "type": "string"
                },
                "role": {
                  "enum": [
                    "user",
                    "assistant"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "role",
                "content"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "id": {
            "type": "string"
          },
          "imageAssetId": {
            "type": "string"
          },
          "isCollapsed": {
            "type": "boolean"
          },
          "isDocked": {
            "type": "boolean"
          },
          "isUser": {
            "type": "boolean"
          },
          "kind": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "previewLabel": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "x",
          "y",
          "title",
          "kind",
          "content",
          "isUser",
          "isCollapsed",
          "code",
          "language",
          "attachmentKind",
          "filePath",
          "mimeType",
          "previewLabel",
          "isDocked",
          "imageAssetId",
          "history"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "pins": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "title",
          "note",
          "x",
          "y"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "revision": {
      "type": "integer"
    },
    "schemaVersion": {
      "type": "integer"
    },
    "snapToGrid": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "revision",
    "nodes",
    "edges",
    "pins",
    "snapToGrid",
    "dragFactor",
    "fontFamily",
    "fontSizePt",
    "fontColor"
  ],
  "title": "SceneState",
  "type": "object"
}
